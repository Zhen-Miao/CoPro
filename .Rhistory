kernel_from_distance_sigma <- function(
sigma, dist_mat, lower_limit = 5e-10) {
kernel_mat <- exp(-0.5 * (dist_mat / sigma_squared)^2)
kernel_mat[kernel_mat < lower_limit] <- 0
return(kernel_mat)
}
