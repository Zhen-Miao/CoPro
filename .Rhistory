## order the gene scores
gs_pt_topgenes <- names(sort(abs(gs_pt), decreasing = TRUE))[1:50]
gs_df <- data.frame(genes = gs_pt_topgenes,
geneScores = gs_pt[gs_pt_topgenes])
library(dplyr)
gs_df <- gs_df %>%
mutate(ScoreType = ifelse(geneScores >= 0, "Positive", "Negative"))
gs_df$genes <- factor(gs_df$genes, levels = rev(gs_df$genes))
ggplot(gs_df)+
geom_col(mapping = aes(x = factor(genes), y = geneScores, fill = ScoreType))+
labs(title = "Top Gene Scores for Fibroblast", x = "Genes", y = "Gene Scores",
subtitle = "CV_2") +
scale_fill_manual(values = c("Positive" = "#2ca02c", "Negative" = "#ff7f0e")) +
coord_flip()+
theme_classic()
ggsave("top gene scores for Fib, all_PT vs Fib 2nd.pdf", width = 5, height = 7)
