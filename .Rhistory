### run CoPro on kidney data
library(Seurat)
library(ggplot2)
setwd("/Users/zhenmiao/Documents/GitHub/CoPro/")
devtools::load_all()
setwd("/Users/zhenmiao/Dropbox/DIALOGUE_plus project/Data/kidney_seqFISH/")
kid <- readRDS("kidney_IRI2_with_xy.rds") ## IRI 2 sample only
library("CoPro")
library_paths <- c(
"fields", "ggplot2", "tictoc", "irlba",
"Matrix", "ggsci", "ape"
)
# Load required libraries
lapply(library_paths, library, character.only = TRUE)
n_pca <- 40 ## number of top PCs to retain
cell_types <- c("all_PT", "Fib")
n_cell_types <- length(cell_types)
horizontal_dist_scale <- 1
vertical_dist_scale <- 1
## get the subset from the data
meta <- kid@meta.data
ra <- t(kid@assays$Spatial@data)
meta$Celltype <- as.character(meta$Celltype)
meta$Celltype[meta$Celltype %in% c("all_PT", "PTS1", "PTS2", "PTS3")] = "all_PT"
subset_cells <- meta$Celltype %in% cell_types
ra <- ra[subset_cells, ]
meta <- meta[subset_cells, ]
## make sure coordinates are numeric
meta$x <- as.numeric(meta$x_um) / 1000
meta$y <- as.numeric(meta$y_um) / 1000
## show
tb <- table(meta$ME)
meta_ME <- meta[meta$ME %in% names(tb[tb>500]), ]
meta_ME$ME_5orother <- as.character(meta_ME$ME)
meta_ME$ME_5orother[meta_ME$ME_5orother != "5"] = "other"
location_data <- meta[, c("x", "y")]
cell_type_data <- meta[, "Celltype"]
br <- newCoPro(
normalizedData = ra,
locationData = location_data,
metaData = meta,
cellTypes = cell_type_data
)
br <- subsetData(br, cellTypesOfInterest = cell_types)
br <- computePCA(br, nPCA = n_pca, center = TRUE, scale. = TRUE)
sigma_choice <- sqrt(c(0.01, 0.02, 0.05, 0.1, 0.2))
# sigma_square_choice <- c(0.01, 0.02, 0.05)
## By default, we normalize the distance
br <- computeDistance(br, distType = "Euclidean2D", normalizeDistance = FALSE)
## compute kernel
br <- computeKernelMatrix(br, sigmaValues = sigma_choice)
br <- runSkrCCA(br, scalePCs = TRUE, maxIter = 500, nCC = 4)
br <- computeNormalizedCorrelation(br)
br <- computeGeneAndCellScores(br)
ncorr <- getNormCorr(br)
ggplot(data = ncorr, aes(
x = sigmaSquares,
y = normalizedCorrelation, group = 1
)) +
geom_point() +
geom_line() +
facet_wrap(facets = ~ ct12 + CC_index,
labeller = purrr::partial(label_both, sep = " = ")) +
xlab("Sigma") +
ylab("Norm. Corr.") +
ggtitle(label = "Norm. Corr. across sigma values") +
theme_minimal()
ggplot(data = ncorr, aes(
x = sigmaValues,
y = normalizedCorrelation, group = 1
)) +
geom_point() +
geom_line() +
facet_wrap(facets = ~ ct12 + CC_index,
labeller = purrr::partial(label_both, sep = " = ")) +
xlab("Sigma") +
ylab("Norm. Corr.") +
ggtitle(label = "Norm. Corr. across sigma values") +
theme_minimal()
ncorr
sqrt(c(0.01, 0.02, 0.05, 0.1, 0.2))
?exp
exp(1)
log(exp(3))
ggsave("norm corr using sigma instead of sigma squared.pdf")
