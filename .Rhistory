scale_color_discrete(type = c('darkgreen','#d4f8d4','darkred','#ffd8d8'))+
coord_fixed()+
theme_minimal()
p2 <- ggplot(data = loc_all)+
geom_point(aes(x = x,
y = y,
color = cellScores), size = 0.8)+
coord_fixed()+
theme_minimal()
